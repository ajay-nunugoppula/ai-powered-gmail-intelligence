# App
DEBUG=false
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173

# Supabase (service role — backend only, never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Legacy HS256 secret from Supabase → Settings → API → JWT Settings.
# Required for Gmail OAuth state signing. Token auth also accepts ES256 via JWKS.

# Google OAuth (Gmail API)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/gmail/callback

# AI Models (Phase 3+)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
NVIDIA_API_KEY=your-nvidia-nim-api-key
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# Infrastructure
REDIS_URL=redis://localhost:6379
TOKEN_ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# Gmail sync (optional overrides)
SYNC_MAX_MESSAGES=1000
SYNC_DAYS_BACK=90
GMAIL_REQUESTS_PER_SECOND=10

# Set true only when running the ARQ worker (`arq app.worker.settings.WorkerSettings`)
USE_ARQ_WORKER=false

# AI enrichment (optional overrides)
ENRICHMENT_AUTO_START=true
ENRICHMENT_BATCH_SIZE=50
EMBEDDING_CHUNK_SIZE=400
EMBEDDING_CHUNK_OVERLAP=50
