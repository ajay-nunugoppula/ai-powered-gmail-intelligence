# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Google OAuth (Gmail API)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/gmail/callback

# AI Models
GEMINI_API_KEY=your-gemini-api-key
NVIDIA_API_KEY=your-nvidia-nim-api-key
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# Infrastructure
REDIS_URL=redis://localhost:6379
TOKEN_ENCRYPTION_KEY=generate-a-32-byte-base64-key
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000

# Backend-only (also set CORS_ORIGINS as comma-separated list in production)
DEBUG=false

# Frontend (prefix with VITE_ for Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_API_URL=http://localhost:8000
