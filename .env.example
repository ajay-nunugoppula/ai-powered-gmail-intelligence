# ===========================================
# Gmail Intelligence Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env with real secrets.

# --- App URLs ---
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# --- Google OAuth (Gmail API) ---
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback

# --- JWT Authentication ---
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-random-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=72

# --- Supabase ---
# From: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# --- Google Gemini (Primary AI) ---
# From: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- NVIDIA NIM (Secondary AI - Embeddings & Classification) ---
# From: https://build.nvidia.com (free tier)
NIM_API_KEY=your-nvidia-nim-api-key
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-8b-instruct
NIM_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# --- Gmail Sync Settings ---
GMAIL_SYNC_BATCH_SIZE=50
GMAIL_MAX_RETRIES=5
GMAIL_RATE_LIMIT_DELAY=0.1

# --- Frontend (for Vite) ---
VITE_API_URL=http://localhost:8000/api
